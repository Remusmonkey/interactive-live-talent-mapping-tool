# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# =============================================================================
# Google Sheets backend (Phase 1 - real data for Section 1)
# =============================================================================
#
# The app reads competitor postings + industry signals from a shared Google
# Sheet via a Google Cloud service account. If these values are blank, the
# app falls back to the local CSVs/JSON in data/.
#
# How to set this up (one-time, see README "Setting up the Google Sheets
# backend" for full walkthrough):
#   1. Create a Google Cloud project + service account at
#      console.cloud.google.com
#   2. Enable the Google Sheets API in that project
#   3. Download the service account's JSON key and save it to
#      secrets/google-sheets-key.json (already gitignored)
#   4. Share your workbook with the service account email
#      (talent-mapping-reader@<project>.iam.gserviceaccount.com) as VIEWER
#   5. Get the workbook ID from the Sheet URL - the long string between
#      /d/ and /edit
#   6. Paste both below

GOOGLE_SHEETS_WORKBOOK_ID=
GOOGLE_SHEETS_KEY_FILE=secrets/google-sheets-key.json

# =============================================================================
# Notion publishing (optional)
# =============================================================================
#
# Used by the "Publish snapshot to Notion" button. Leave blank if you do not
# need that feature locally.
#
# Setup steps:
#   1. Go to https://www.notion.so/my-integrations and create a new integration.
#   2. Copy the "Internal Integration Token" into NOTION_TOKEN below.
#   3. In Notion, open the parent page where snapshots will be published.
#      Click the "..." menu -> "Connections" -> add your integration.
#   4. Copy the page ID from the URL (the 32-char hex after the last "-")
#      into NOTION_PARENT_PAGE_ID below.

NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
